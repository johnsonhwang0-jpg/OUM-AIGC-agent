# AI Provider Configuration
# Set to "deepseek" for DeepSeek API (国内可用，推荐)
# Set to "dashscope" for Alibaba Cloud DashScope / Qwen (国内可用)
# Set to "gemini" for Google Gemini API (requires API Key)
# Set to "ollama" for local open-source models (requires Ollama installed)
# Set to "huggingface" for free cloud models (无需 API Key)
AI_PROVIDER="deepseek"

# DeepSeek API Configuration (used when AI_PROVIDER="deepseek")
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY="sk-bfd2fea45b464d9eb599270fe9057cee"
DEEPSEEK_MODEL="deepseek-v4-flash"

# DashScope (阿里云通义千问) Configuration (used when AI_PROVIDER="dashscope")
# 获取 API Key: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=""
DASHSCOPE_MODEL="qwen-plus"

# GEMINI_API_KEY: Required when AI_PROVIDER="gemini"
# You can get a free API key at https://ai.google.dev/
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:8080"

# Hugging Face Configuration (used when AI_PROVIDER="huggingface")
# 推荐模型: Qwen/Qwen2-7B-Instruct, mistralai/Mistral-7B-Instruct-v0.3, google/gemma-7b-it
HUGGINGFACE_MODEL="Qwen/Qwen2-7B-Instruct"
HUGGINGFACE_TOKEN=""  # 可选，增加请求限额

# Ollama Model Configuration (used when AI_PROVIDER="ollama")
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_HOST="http://localhost:11434"
